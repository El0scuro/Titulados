# Dependencias

node_modules/

# Builds / compilación

dist/
build/
out/

# Archivos de entorno (MUY importante no subirlos)

.env
.env.*
!.env.example

# Logs

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sistema operativo

.DS_Store
Thumbs.db

# Archivos temporales

tmp/
temp/

# IDEs / editores

.vscode/
.idea/
*.swp

# Docker (opcional, según tu caso)

docker-compose.override.yml

# Archivos de base de datos locales

*.sql
*.sqlite
*.db

# Archivos de cache

.cache/
.npm/

# ============================
# Archivos subidos por usuarios
# ============================

# Ignorar todo el contenido de la carpeta archivos
back-end/src/archivos/*

# Mantener las carpetas
!back-end/src/archivos/actas/
!back-end/src/archivos/archivos_guia/
!back-end/src/archivos/archivos_Informante/
!back-end/src/archivos/archivos_secretaria/
!back-end/src/archivos/archivos_tesis/
!back-end/src/archivos/fichas_inscripcion/
!back-end/src/archivos/reporte_estudiantes/

# Ignorar el contenido de cada carpeta
back-end/src/archivos/actas/*
back-end/src/archivos/archivos_guia/*
back-end/src/archivos/archivos_Informante/*
back-end/src/archivos/archivos_secretaria/*
back-end/src/archivos/archivos_tesis/*
back-end/src/archivos/fichas_inscripcion/*
back-end/src/archivos/reporte_estudiantes/*

# Mantener únicamente los .gitkeep
!back-end/src/archivos/actas/.gitkeep
!back-end/src/archivos/archivos_guia/.gitkeep
!back-end/src/archivos/archivos_Informante/.gitkeep
!back-end/src/archivos/archivos_secretaria/.gitkeep
!back-end/src/archivos/archivos_tesis/.gitkeep
!back-end/src/archivos/fichas_inscripcion/.gitkeep
!back-end/src/archivos/reporte_estudiantes/.gitkeep